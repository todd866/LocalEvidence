# LocalEvidence config & keys. Copy to `.env` (gitignored) and fill in.
# Loaded automatically (config.load_dotenv); a real exported env var always wins.

# Polite-pool contact for the OA APIs. Unpaywall 422s a placeholder — use your real address.
LOCALEVIDENCE_EMAIL=

# Default model for synthesis (free, on-device). e.g. ollama:qwen2.5:14b
LOCALEVIDENCE_MODEL=

# Capability gate tier for that model: small | large (default: small / fail-safe)
# LOCALEVIDENCE_MODEL_TIER=

# Point retrieval / the paper store at a corpus kept elsewhere
# LOCALEVIDENCE_PASSAGES=/path/to/passages
# LOCALEVIDENCE_LIBRARY=/path/to/library

# OPTIONAL — eval arm only. Paid API backends use YOUR key; free-local is the default.
# OpenRouter is one key for ~every model (grade-sweeps): openrouter:provider/model
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
